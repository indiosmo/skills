{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/msi/llm_workspace/skills/claude/scripts/block-git-write.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "allium@juxt-plugins": true
  },
  "extraKnownMarketplaces": {
    "juxt-plugins": {
      "source": {
        "source": "github",
        "repo": "juxt/claude-plugins"
      }
    }
  },
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "autoMemoryEnabled": false,
  "verbose": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754148821130
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": ["/tmp"]
    }
  }
}
