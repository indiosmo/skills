{
  "$schema": "https://opencode.ai/config.json",

  "lsp": false,

  "permission": {
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "ctest *": "allow",
      "ls *": "allow",
      "pgrep *": "allow",
      "ag *": "allow",
      "rg *": "allow",
      "printf *": "allow",
      "fzf *": "allow",
      "tree *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "git status *": "allow",
      "git show *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git blame *": "allow",
      "_build/*/test/*": "allow"
    },
    "edit": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  },

  "mcp": {
    "Ref": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp",
      "enabled": true,
      "headers": {
        "x-ref-api-key": "<key>"
      }
    },
    "Context7": {
      "type": "local",
			"command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "<key>"],
      "enabled": true
    },
    "cclsp": {
      "type": "local",
			"command": ["npx", "-y", "cclsp@latest"],
      "enabled": true,
      "environment": {
        "CCLSP_CONFIG_PATH": "/home/msi/.config/claude/cclsp.json"
      }
    }

  }
}
